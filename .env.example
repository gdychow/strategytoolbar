# Copy to .env and fill in real values. .env is gitignored — never commit
# real secrets or email addresses here.

# Comma-separated, case-insensitive. Whoever's email matches (from the
# verified Microsoft ID token) gets isAdmin=true at session time.
ADMIN_EMAILS=you@example.com

# Random long string used to sign session cookies. Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=

# Postgres password — used both by the db service and by the app's
# DATABASE_URL (see docker-compose.yml).
POSTGRES_PASSWORD=
